{
  "icon_theme": {
    "mode": "dark",
    "light": "Zed (Default)",
    "dark": "Zed (Default)"
  },
  "cli_default_open_behavior": "existing_window",
  "project_panel": {
    "dock": "left"
  },
  "outline_panel": {
    "dock": "left"
  },
  "collaboration_panel": {
    "dock": "left"
  },
  "git_panel": {
    "dock": "left"
  },
  "diff_view_style": "split",
  "vim_mode": true,
  "ui_font_size": 13,
  "buffer_font_size": 13,
  "use_autoclose": false,
  "wrap_guides": [80],
  "theme": {
    "mode": "dark",
    "light": "Ayu Light",
    "dark": "Gruvbox Dark Hard"
  },
  "scrollbar": {
    "show": "never",
  },
  "ui_font_family": "Berkeley Mono",
  "buffer_font_family": "Berkeley Mono",
  "buffer_line_height": {
    "custom": 1.25,
  },
  "terminal": {
    "dock": "bottom",
    "font_size": 13,
    "font_family": "Berkeley Mono",
    "line_height": {
      "custom": 1.25,
    },
    "env": {
      "GIT_EDITOR": "zed --wait",
    },
  },
  "indent_guides": { "enabled": false },
  "inlay_hints": {
    "enabled": true,
  },
  "agent": {
    "dock": "right",
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-3-5-sonnet-latest",
    },
  },
  "soft_wrap": "none",
  "cursor_blink": false,
  "current_line_highlight": "none",
  "preview_tabs": {
    "enabled": true,
    "enable_preview_multibuffer_from_code_navigation": true,
    "enable_keep_preview_on_code_navigation": false,
  },
  "lsp": {
    "gopls": {
      "initialization_options": {
        "usePlaceholders": true,
        "completeUnimported": false,
        "experimentalPostfixCompletions": true,
        "hints": {
          "assignVariableTypes": false,
          "compositeLiteralFields": false,
          "compositeLiteralTypes": false,
          "constantValues": true,
          "functionTypeParameters": true,
          "parameterNames": true,
          "rangeVariableTypes": true,
        },
      },
    },
  },
  "languages": {
    "Markdown": {
      "completions": {
        "words": "disabled",
      },
      "show_edit_predictions": false,
      "preferred_line_length": 80,
      "format_on_save": "off",
      "prettier": {
        "allowed": true,
      },
    },
    "JSON": {
      "prettier": {
        "allowed": true,
        "parser": "json",
      },
    },
    "JavaScript": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": [
            "exec",
            "biome",
            "format",
            "--stdin-file-path",
            "{buffer_path}",
          ],
        },
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
        "source.organizeImports.biome": true,
      },
    },
    "TypeScript": {
      "formatter": {
        "external": {
          "command": "pnpm",
          "arguments": [
            "exec",
            "biome",
            "format",
            "--stdin-file-path",
            "{buffer_path}",
          ],
        },
      },
      "code_actions_on_format": {
        "source.organizeImports.biome": true,
      },
    },
    "Svelte": {
      "prettier": {
        "allowed": true,
      },
      "code_actions_on_format": {
        "source.fixAll.eslint": true,
      },
    },
    "CSS": {
      "prettier": {
        "allowed": true,
      },
    },
    "Rust": {
      "use_on_type_format": false,
    },
  },
}
